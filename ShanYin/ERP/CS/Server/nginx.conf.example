# Nginx 配置示例 - 闪饮 ERP
# 将此文件复制到 /etc/nginx/sites-available/shanyin-erp
# 然后软链接到 /etc/nginx/sites-enabled/shanyin-erp

server {
    listen 80;
    server_name erp.example.com;  # 修改为你的域名

    # 重定向 HTTP 到 HTTPS（生产环境）
    # return 301 https://$server_name$request_uri;

    # 上线时取消注释下行，开启 HTTPS
    # listen 443 ssl http2;

    # SSL 证书（上线时配置）
    # ssl_certificate /etc/letsencrypt/live/erp.example.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/erp.example.com/privkey.pem;
    # ssl_trusted_certificate /etc/letsencrypt/live/erp.example.com/chain.pem;

    root /var/www/shanyin-erp/client/dist;  # React 构建产物目录
    index index.html;

    # 安全响应头
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Gzip 压缩
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/json application/xml;

    # 静态资源缓存
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # API 反向代理到 FastAPI
    location /api/ {
        # FastAPI 服务地址
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;

        # WebSocket 支持（用于 events/stream）
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # 传递真实 IP
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 超时设置
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        # 不缓存 API 响应
        add_header Cache-Control "no-store, no-cache, must-revalidate";
    }

    # React Router 支持（History 模式）
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 健康检查
    location /health {
        return 200 'OK';
        add_header Content-Type text/plain;
    }
}
